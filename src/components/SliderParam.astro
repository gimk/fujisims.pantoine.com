---
interface SliderConfig {
    min: number;
    max: number;
    increment: number;
}

const SLIDER_CONFIGS: Record<string, SliderConfig> = {
    "Highlight":        { min: -2, max: 4,  increment: 0.5 },
    "Shadow":           { min: -2, max: 4,  increment: 0.5 },
    "Color":            { min: -4, max: 4,  increment: 1   },
    "Sharpness":        { min: -4, max: 4,  increment: 1   },
    "Noise Reduction":  { min: -4, max: 4,  increment: 1   },
    "Clarity":          { min: -5, max: 5,  increment: 1   },
};

interface Props {
    label: string;
    value: number;
}

const { label, value } = Astro.props;
const config = SLIDER_CONFIGS[label];

if (!config) throw new Error(`SliderParam: no config found for setting "${label}"`);

const { min, max, increment } = config;

const clamped = Math.min(max, Math.max(min, value));
const percent = ((clamped - min) / (max - min)) * 100;
const zeroPercent = ((0 - min) / (max - min)) * 100;
const displayValue = value > 0 ? `+${value}` : `${value}`;

const steps = Math.round((max - min) / increment);
const ticks = Array.from({ length: steps + 1 }, (_, i) => min + i * increment);
---

<div class="param-item">
    <div class="param-info">
        <span class="label">{label}</span>
        <span class="value">{displayValue}</span>
    </div>
    <div class="slider-track">
        {ticks.map(tick => (
            <div
                class={`slider-tick${tick === 0 ? ' zero' : ''}`}
                style={`left: ${((tick - min) / (max - min)) * 100}%`}
            ></div>
        ))}
        <div class="slider-center" style={`left: ${zeroPercent}%`}></div>
        <div class="slider-dot" style={`left: ${percent}%`}></div>
    </div>
</div>
