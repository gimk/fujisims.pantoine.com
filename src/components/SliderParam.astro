---
interface Props {
    label: string;
    value: number;
    min: number;
    max: number;
    increment: number;
}

const { label, value, min, max, increment } = Astro.props;

// Clamp and compute percentage position
const clamped = Math.min(max, Math.max(min, value));
const percent = ((clamped - min) / (max - min)) * 100;

// Center tick position (where 0 sits on the track)
const zeroPercent = ((0 - min) / (max - min)) * 100;

// Display string
const displayValue = value > 0 ? `+${value}` : `${value}`;

// Number of ticks
const steps = Math.round((max - min) / increment);
const ticks = Array.from({ length: steps + 1 }, (_, i) => min + i * increment);
---

<div class="param-item">
    <div class="param-info">
        <span class="label">{label}</span>
        <span class="value">{displayValue}</span>
    </div>
    <div class="slider-track">
        <!-- Tick marks -->
        {ticks.map(tick => (
            <div
                class={`slider-tick${tick === 0 ? ' zero' : ''}`}
                style={`left: ${((tick - min) / (max - min)) * 100}%`}
            ></div>
        ))}
        <!-- Zero center marker (prominent) -->
        <div class="slider-center" style={`left: ${zeroPercent}%`}></div>
        <!-- Value knob -->
        <div class="slider-dot" style={`left: ${percent}%`}></div>
    </div>
</div>
