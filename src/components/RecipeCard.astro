---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
    slug: string;
    name: string;
    filmSimulation: string;
    coverImage: ImageMetadata;
    refNo: string;
}

const { slug, name, filmSimulation, coverImage, refNo } = Astro.props;
---

<a href={`/recipes/${slug}`} class="recipe-card" id={`recipe-card-${slug}`}>
    <div class="recipe-card-image">
        <Image src={coverImage} width={800} alt={`${name} cover`} loading="lazy" />
        <div class="recipe-card-overlay"></div>
    </div>
    <div class="recipe-card-body">
        <span class="recipe-card-ref">{refNo}</span>
        <h2 class="recipe-card-name">{name}</h2>
        <p class="recipe-card-sim">{filmSimulation}</p>
    </div>
    <div class="recipe-card-arrow">
        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </div>
</a>
