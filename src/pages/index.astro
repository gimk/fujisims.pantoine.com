---
import "../styles/global.css";
import { getCollection } from "astro:content";
import RecipeCard from "../components/RecipeCard.astro";

const recipes = await getCollection("recipes");

// For each recipe, extract the cover image and film simulation
const recipeItems = recipes.map((entry) => {
  const filmSim =
    entry.data.core.find(
      (p: { label: string }) => p.label === "Film Simulation",
    )?.value ?? "Unknown";
  return {
    slug: entry.id,
    name: entry.data.name,
    filmSimulation: String(filmSim),
    coverImage: entry.data.images[0],
    refNo: entry.data.refNo,
  };
});
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fujifilm Simulation Recipes</title>
    <meta
      name="description"
      content="A curated collection of Fujifilm film simulation recipes for X-series cameras."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/favicon.png?v=1" />
  </head>
  <body class="home">
    <div class="frame home-frame">
      <header class="animate-in home-header">
        <div class="home-title-block">
          <div class="status-led"></div>
          <div>
            <h1>Simulation Recipes</h1>
            <p class="home-subtitle">
              Fujifilm X-System · Film Protocol Archive
            </p>
          </div>
        </div>
        <div class="header-right home-header-right">
          <a
            href="/submit"
            class="last-recipe-pill"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            <span>Submit a recipe</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="last-recipe-pill-arrow"
              aria-hidden="true"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
          <a
            href="https://www.pantoine.com"
            target="_blank"
            rel="noopener noreferrer"
            class="last-recipe-pill"
          >
            <svg
              width="13"
              height="13"
              viewBox="12.7 17.8 37 37"
              xmlns="http://www.w3.org/2000/svg"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M 31.2344 54.7305 C 31.8438 54.7305 32.2891 54.2852 32.4062 53.6524 C 34.0703 40.8086 35.8750 38.8633 48.5781 37.4570 C 49.2344 37.3867 49.6797 36.8945 49.6797 36.2852 C 49.6797 35.6758 49.2344 35.2070 48.5781 35.1133 C 35.8750 33.7070 34.0703 31.7617 32.4062 18.9180 C 32.2891 18.2852 31.8438 17.8633 31.2344 17.8633 C 30.6250 17.8633 30.1797 18.2852 30.0860 18.9180 C 28.4219 31.7617 26.5938 33.7070 13.9140 35.1133 C 13.2344 35.2070 12.7891 35.6758 12.7891 36.2852 C 12.7891 36.8945 13.2344 37.3867 13.9140 37.4570 C 26.5703 39.1211 28.3281 40.8321 30.0860 53.6524 C 30.1797 54.2852 30.6250 54.7305 31.2344 54.7305 Z"
              ></path>
            </svg>
            <span>Check my portfolio</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="last-recipe-pill-arrow"
              aria-hidden="true"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
          <div class="meta-data">
            SYSTEM: X-TRANS V<br />
            RECIPES: {recipeItems.length.toString().padStart(3, "0")}
          </div>
        </div>
      </header>

      <main class="recipe-grid animate-in delay-1">
        {
          recipeItems.map((recipe) => (
            <RecipeCard
              slug={recipe.slug}
              name={recipe.name}
              filmSimulation={recipe.filmSimulation}
              coverImage={recipe.coverImage}
              refNo={recipe.refNo}
            />
          ))
        }
      </main>

      <footer class="animate-in delay-2">
        <span>Fujifilm Simulation Protocol © 2026</span>
        <span>X-SYSTEM_V3 // ARCHIVE</span>
      </footer>
    </div>
  </body>
</html>
