---
import "../styles/global.css";
import { getCollection } from "astro:content";
import RecipeCard from "../components/RecipeCard.astro";

const recipes = await getCollection("recipes");

// For each recipe, extract the cover image and film simulation
const recipeItems = recipes.map((entry) => {
  const filmSim =
    entry.data.core.find(
      (p: { label: string }) => p.label === "Film Simulation",
    )?.value ?? "Unknown";
  return {
    slug: entry.id,
    name: entry.data.name,
    filmSimulation: String(filmSim),
    coverImage: entry.data.images[0],
    refNo: entry.data.refNo,
  };
});
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fujifilm Simulation Recipes</title>
    <meta
      name="description"
      content="A curated collection of Fujifilm film simulation recipes for X-series cameras."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="home">
    <div class="frame home-frame">
      <header class="animate-in home-header">
        <div class="home-title-block">
          <div class="status-led"></div>
          <div>
            <h1>Simulation Recipes</h1>
            <p class="home-subtitle">
              Fujifilm X-System · Film Protocol Archive
            </p>
          </div>
        </div>
        <div class="meta-data">
          SYSTEM: X-SYSTEM_V3<br />
          RECIPES: {recipeItems.length.toString().padStart(3, "0")}
        </div>
      </header>

      <main class="recipe-grid animate-in delay-1">
        {
          recipeItems.map((recipe) => (
            <RecipeCard
              slug={recipe.slug}
              name={recipe.name}
              filmSimulation={recipe.filmSimulation}
              coverImage={recipe.coverImage}
              refNo={recipe.refNo}
            />
          ))
        }
      </main>

      <footer class="animate-in delay-2">
        <span>Fujifilm Simulation Protocol © 2026</span>
        <span>X-SYSTEM_V3 // ARCHIVE</span>
      </footer>
    </div>
  </body>
</html>
